# StreetStudio environment (example — copy to .env and fill real values).
# No secrets are committed. Values below match docker/docker-compose.yml defaults
# for LOCAL DEVELOPMENT ONLY. Use strong, unique secrets in every real deployment.

# --- Core ---
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# --- PostgreSQL ---
DATABASE_URL=postgres://streetstudio:streetstudio@localhost:5432/streetstudio

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Object storage (S3-compatible; MinIO for local dev) ---
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=streetstudio
S3_ACCESS_KEY_ID=streetstudio
S3_SECRET_ACCESS_KEY=streetstudio
S3_FORCE_PATH_STYLE=true

# --- Auth ---
# Generate with: openssl rand -base64 48
SESSION_SECRET=
JWT_SIGNING_KEY=

# --- SMTP (MailHog for local dev) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@streetstudio.local

# --- Media processing ---
FFMPEG_PATH=/usr/bin/ffmpeg

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
