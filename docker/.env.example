# =============================================================================
# StreetStudio self-hosting configuration (example)
#
# Copy this file to `docker/.env` and replace every placeholder before running
# the stack. NEVER commit a real `.env` — it is git-ignored.
#
#   cp docker/.env.example docker/.env
#
# Each variable below maps to a key in the platform config schema
# (packages/config). REQUIRED values must be set; OPTIONAL values fall back to
# the secure, spec-aligned defaults shown.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — core service configuration
# -----------------------------------------------------------------------------

# instanceId — stable UUID identifying this API_Service instance.
# Generate one with: node -e "console.log(crypto.randomUUID())"
INSTANCE_ID=00000000-0000-4000-8000-000000000000

# auth.jwtSecret — secret used to sign/verify JWT access tokens.
# MUST be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# http.port — TCP port the HTTP server binds to (1..65535).
HTTP_PORT=8080

# http.publicBaseUrl — public URL the service is reachable at (http/https).
# For production behind TLS, use your https:// origin.
HTTP_PUBLIC_BASE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# REQUIRED — PostgreSQL (database.url)
# In-stack Postgres is wired automatically from these values by docker-compose.
# For an external / HA database, set DATABASE_URL directly and ignore the rest.
# -----------------------------------------------------------------------------
POSTGRES_USER=streetstudio
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=streetstudio
POSTGRES_PORT=5432
# Override to target an external/HA PostgreSQL endpoint instead of the in-stack one:
# DATABASE_URL=postgres://user:password@db-host:5432/streetstudio

# -----------------------------------------------------------------------------
# REQUIRED — Redis (redis.url)
# In-stack Redis is wired automatically. Override REDIS_URL to target an
# external instance or a Redis Cluster (see infrastructure/README.md).
# -----------------------------------------------------------------------------
REDIS_PORT=6379
# REDIS_URL=redis://redis-host:6379

# -----------------------------------------------------------------------------
# REQUIRED — Object storage (storage.*) — MinIO / S3-compatible
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=streetstudio
MINIO_ROOT_PASSWORD=replace-with-a-strong-object-store-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
STORAGE_BUCKET=streetstudio-media
STORAGE_REGION=us-east-1

# -----------------------------------------------------------------------------
# OPTIONAL — tuning (secure defaults applied by packages/config when unset)
# -----------------------------------------------------------------------------

# storage.signedUploadTtlSeconds — validity window for signed upload targets.
# Bounded 60..3600, default 900.
STORAGE_SIGNED_UPLOAD_TTL_SECONDS=900

# rateLimit.perWindow — requests allowed per window per client. Default 100.
RATE_LIMIT_PER_WINDOW=100

# rateLimit.windowSeconds — length of the rate-limit rolling window. Default 60.
RATE_LIMIT_WINDOW_SECONDS=60
