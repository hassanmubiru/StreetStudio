{
  "name": "streetstudio",
  "version": "0.1.0",
  "private": true,
  "description": "StreetStudio - open-source asynchronous collaboration platform built on the StreetJS framework.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "build:clean": "tsc -b --clean",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "boundary:check": "echo \"boundary analyzer wired in task 1.2\" && exit 0",
    "graph:check": "tsc -b packages/config && node packages/config/dist/dependency-graph.cli.js"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "fast-check": "^3.23.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
